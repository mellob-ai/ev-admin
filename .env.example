# Set to true to enable backend API integration in the admin panel.
VITE_USE_BACKEND_API=false

# Backend base URL, e.g. https://ev-api.aks2.mellob.in or http://localhost:4000
VITE_API_BASE_URL=

# App key — required by the Go backend's IsProtectedAppRequest middleware
VITE_APP_KEY=

# Admin key — required by the Go backend's IsKarmaAdmin middleware for /v1/admin routes
VITE_ADMIN_KEY=

# Optional request timeout in ms
VITE_API_TIMEOUT_MS=15000

# Optional verbose API logs in browser console
VITE_API_DEBUG=false
